    {
      "cell_type": "code",
      "source": [
        "from sklearn.decomposition import PCA\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "def get_embedding(sequence):\n",
        "    inputs = tokenizer(sequence, return_tensors=\"pt\")\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model(**inputs)\n",
        "\n",
        "    embedding = outputs.last_hidden_state.mean(dim=1)\n",
        "\n",
        "    return embedding.squeeze().numpy()"
      ],
      "metadata": {
        "id": "batVqpCX-fIq"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "chymosin_seq = \"\"\n",
        "amylase_seq = \"\"\n",
        "lactase_seq = \"\"\n",
        "\n",
        "embeddings = np.array([\n",
        "    get_embedding(chymosin_seq),\n",
        "    get_embedding(amylase_seq),\n",
        "    get_embedding(lactase_seq)\n",
        "])"
      ],
      "metadata": {
        "id": "gfHKlP_6_G7u"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "pca = PCA(n_components=2)\n",
        "\n",
        "coords = pca.fit_transform(embeddings)"
      ],
      "metadata": {
        "id": "9wjTBi8cAIu1"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "plt.figure(figsize=(6,5))\n",
        "\n",
        "labels = [\"Chymosin\", \"Amylase\", \"Lactase\"]\n",
        "\n",
        "for i, label in enumerate(labels):\n",
        "    plt.scatter(coords[i,0], coords[i,1])\n",
        "    plt.annotate(label, (coords[i,0], coords[i,1]))\n",
        "\n",
        "plt.title(\"ESM-2 Protein Embedding Space\")\n",
        "plt.xlabel(\"PC1\")\n",
        "plt.ylabel(\"PC2\")\n",
        "\n",
        "plt.show()"
      ],
